# Ingestion Service (.env.example)
NODE_ENV=production

# Solana RPC WebSocket (e.g., Helius WS)
RPC_WSS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Helius (optional explicit parse URL; otherwise derived from HELIUS_API_KEY)
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
HELIUS_PARSE_URL=https://api.helius.xyz/v0/transactions/?api-key=YOUR_HELIUS_API_KEY

# Pump.fun program ID
PUMPFUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
QUEUE_NEW_TOKEN=new_token_unprocessed
QUEUE_TRADES=pumpfun_trades

# Reconnect backoff
RECONNECT_MAX_BACKOFF_MS=30000
