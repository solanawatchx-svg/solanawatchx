# Analytics Service (.env.example)
PYTHONUNBUFFERED=1

# Database
DATABASE_URL=postgresql+asyncpg://swx:swxpassword@postgres:5432/swx

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
QUEUE_NEW_TOKEN=new_token_unprocessed
QUEUE_TRADES=pumpfun_trades
EXCHANGE_EVENTS=swx_events

# External providers
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
SOLANATRACKER_DATA_API_KEY=YOUR_SOLANATRACKER_KEY
BITQUERY_API_KEY=YOUR_BITQUERY_KEY
COINGECKO_API_KEY=YOUR_COINGECKO_KEY
COINMARKETCAP_API_KEY=YOUR_CMC_KEY

# RPC HTTP endpoint for getTokenLargestAccounts
RPC_HTTP_ENDPOINT=https://api.mainnet-beta.solana.com

# Socials
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER
APIVOID_API_KEY=YOUR_APIVOID_KEY
TELEGRAM_API_ID=
